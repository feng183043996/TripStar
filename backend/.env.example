
# LLM配置 (从HelloAgents继承,如需覆盖可在此配置)
# 模型名称
LLM_MODEL_ID=your-model-name

# API密钥
LLM_API_KEY=your-api-key-here

# 服务地址
LLM_BASE_URL=your-api-base-url

# 超时时间（可选，默认60秒）
LLM_TIMEOUT=60

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 日志级别
LOG_LEVEL=INFO

# 小红书 Cookie
# 直接填浏览器请求头中的 Cookie 字符串，例如:
# XHS_COOKIE="a1=xxx; web_session=xxx; webId=xxx"
# 也兼容浏览器导出的 JSON Cookie 列表/对象串，程序会自动转换。
XHS_COOKIE="这里填写您网页端登录小红书复制来的 Cookie"

# 高德地图API配置
VITE_AMAP_WEB_KEY=your_amap_api_key_here

# 高德地图 JS API 2.0 安全密钥（前端构建时注入，可选）
# 在高德开放平台 → 应用管理 → 应用列表 → 安全密钥 中获取
# VITE_AMAP_WEB_JS_SECURITY_KEY=

# Google Maps API 配置 (可选, 填写后优先使用 Google Maps，留空则使用高德)
# 需要在 Google Cloud Console 开启: Places API, Geocoding API, Routes API, Weather API
GOOGLE_MAPS_API_KEY=

# Google Maps 代理 (可选, 国内环境需要代理才能访问 Google API)
# 支持 HTTP/HTTPS 代理和 SOCKS5 代理，示例:
#   GOOGLE_MAPS_PROXY=http://127.0.0.1:7890
#   GOOGLE_MAPS_PROXY=socks5://127.0.0.1:1080
GOOGLE_MAPS_PROXY=
